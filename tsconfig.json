{
    "compilerOptions": {
        "declaration": true,
        "strict": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "target": "es2018",
        "module": "esnext",
        "moduleResolution": "bundler",
        "rootDir": "./source",
        "declarationDir": "./build",
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true
    },
    "include": ["source/**/*.ts"],
    "exclude": ["source/**/*.test.ts", "source/tests/**"]
}
